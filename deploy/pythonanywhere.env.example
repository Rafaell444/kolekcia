# Copy to backend/.env on PythonAnywhere (Bash console: nano ~/kolekcia/backend/.env)

SECRET_KEY=generate-a-long-random-secret-key
DEBUG=False
DJANGO_SETTINGS_MODULE=kolekcia.settings.production

# SQLite on PythonAnywhere (file-based database)
# Keep this path inside your project directory.
DATABASE_URL=sqlite:////home/YOUR_USERNAME/kolekcia/backend/db.sqlite3

ALLOWED_HOSTS=YOUR_USERNAME.pythonanywhere.com
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app
CSRF_TRUSTED_ORIGINS=https://your-app.vercel.app
FRONTEND_URL=https://your-app.vercel.app
GOOGLE_CLIENT_ID=your-google-oauth-web-client-id.apps.googleusercontent.com

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@kolekcia.com
