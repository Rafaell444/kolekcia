# Local/dev: django-insecure-* keys are fine while DEBUG=True.
# Production: set a long random SECRET_KEY (e.g. `python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"`).
# Starting with django-insecure- while DEBUG=False raises ImproperlyConfigured.
SECRET_KEY=django-insecure-change-me-in-production

# Local/dev: True. Production: must be False.
DEBUG=True

DATABASE_URL=sqlite:///db.sqlite3
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@kolekcia.com
FRONTEND_URL=http://localhost:3000

# Google Sign-In — OAuth 2.0 Web Client ID from Google Cloud Console
GOOGLE_CLIENT_ID=211332352910-hg5rv8ucqvkca8rt73l8intjt2r7k229.apps.googleusercontent.com

# Production (PythonAnywhere) — see deploy/pythonanywhere.env.example
# DJANGO_SETTINGS_MODULE=kolekcia.settings.production
# SECRET_KEY=<strong-random-secret-not-django-insecure>
# DEBUG=False
# DATABASE_URL=sqlite:////home/YOUR_USERNAME/kolekcia/backend/db.sqlite3
# ALLOWED_HOSTS=USER.pythonanywhere.com
# CORS_ALLOWED_ORIGINS=https://your-app.vercel.app
# FRONTEND_URL=https://your-app.vercel.app
